<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hydravision.mapper.device.DeviceMapper">

    <resultMap id="BaseResultMap" type="com.hydravision.entity.device.Device">
        <id column="id" property="id"/>
        <result column="device_id" property="deviceId"/>
        <result column="device_name" property="deviceName"/>
        <result column="device_type" property="deviceType"/>
        <result column="device_model" property="deviceModel"/>
        <result column="manufacturer" property="manufacturer"/>
        <result column="serial_number" property="serialNumber"/>
        <result column="area_id" property="areaId"/>
        <result column="location_name" property="locationName"/>
        <result column="longitude" property="longitude"/>
        <result column="latitude" property="latitude"/>
        <result column="altitude" property="altitude"/>
        <result column="install_date" property="installDate"/>
        <result column="data_interval" property="dataInterval"/>
        <result column="communication_type" property="communicationType"/>
        <result column="power_type" property="powerType"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <!-- 获取设备统计 -->
    <select id="getStatistics" resultType="com.hydravision.vo.device.DeviceStatisticsVO">
        SELECT
            COUNT(*) as totalCount,
            SUM(CASE WHEN status = 1 THEN 1 ELSE 0 END) as onlineCount,
            SUM(CASE WHEN status = 2 THEN 1 ELSE 0 END) as offlineCount,
            SUM(CASE WHEN status = 3 THEN 1 ELSE 0 END) as warningCount,
            SUM(CASE WHEN status = 4 THEN 1 ELSE 0 END) as maintenanceCount
        FROM hf_device
        WHERE is_deleted = 0
    </select>

    <!-- 按类型统计 -->
    <select id="getTypeStatistics" resultType="map">
        SELECT
            device_type as deviceType,
            COUNT(*) as count
        FROM hf_device
        WHERE is_deleted = 0
        GROUP BY device_type
    </select>

    <!-- 按区域统计 -->
    <select id="getAreaStatistics" resultType="map">
        SELECT
            area_id as areaId,
            COUNT(*) as count
        FROM hf_device
        WHERE is_deleted = 0
        GROUP BY area_id
    </select>

    <!-- 获取在线设备列表 -->
    <select id="getOnlineDevices" resultMap="BaseResultMap">
        SELECT *
        FROM hf_device
        WHERE status = 1 AND is_deleted = 0
        ORDER BY update_time DESC
    </select>

</mapper>
